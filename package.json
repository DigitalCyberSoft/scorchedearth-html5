{
  "name": "scorchedearth-html5",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser (TypeScript + Canvas + Web Audio) port of Scorched Earth v1.5, differential-verified against the Python port.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "bash scripts/capped.sh vitest run",
    "test:uncapped": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage:node": "CAP_MEM=8G bash scripts/capped.sh vitest run --coverage",
    "coverage:merge": "node scripts/coverage_merge.mjs",
    "coverage:all": "CAP_MEM=12G bash scripts/capped.sh bash scripts/coverage_all.sh"
  },
  "devDependencies": {
    "@types/node": "^22.8.0",
    "@vitest/coverage-v8": "^2.1.9",
    "monocart-coverage-reports": "^2.12.12",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
